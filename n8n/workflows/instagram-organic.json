      "id": "ig-list-media",
      "name": "IG: List Media",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        300
      ],
      "credentials": {
        "facebookGraphApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Meta Graph API"
        }
