# Shopify Bulk Backfill - 設定ファイル
# このファイルをコピーして .env として保存し、値を埋めてください
#   cp .env.example .env

# Shopify ストアのドメイン (xxx.myshopify.com 形式)
SHOPIFY_SHOP=kubell.myshopify.com

# Dev Dashboard で作成した n8n ETL アプリの認証情報
SHOPIFY_CLIENT_ID=bf0bf6d7c70a958718a6b069bf59e88b
SHOPIFY_CLIENT_SECRET=shpss_REPLACE_WITH_ACTUAL_SECRET

# 任意: 既に手動取得した Admin API access token があればここに直接設定
# (設定すると client_credentials grant をスキップ)
SHOPIFY_ACCESS_TOKEN=

# BigQuery 投入先プロジェクト
GCP_PROJECT_ID=campwill-ec
